# Copy this file to deepwiki.env only when you want persistent overrides.
# Command-line flags passed to deepwiki.sh take precedence.

OLLAMA_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_EMBED_MODEL=nomic-embed-text
DEEPWIKI_API_PORT=8001
DEEPWIKI_PROJECT_NAME=deepwiki-open-local
# auto, host or bridge. "auto" selects host on native Linux and bridge on
# Docker Desktop, WSL, macOS and Windows.
DEEPWIKI_NETWORK_MODE=auto
